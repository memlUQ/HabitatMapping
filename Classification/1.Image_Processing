/////////////////// ---------- (F) SEGMENTATION ---------- ///////////////////
// (1) SNIC (simple non-iterative clustering) segmentation
var run_snic = function(bands) {
  return(
  ee.Algorithms.Image.Segmentation.SNIC({
  image: bands,
  seeds: ee.Algorithms.Image.Segmentation.seedGrid(18, "hex"),
  //size: 1000,
  neighborhoodSize: 9,
  compactness: 4,
  connectivity: 8
  })
  );
};

// (2) apply segmentation
var segmented_data_mean = run_snic(rawImageWithStats
                            .addBands(DWimage)
                            .addBands(depth_glcm)
                            .addBands(blue_glcm)
                            .addBands(green_glcm)
                            .addBands(red_var)
                            .addBands(depth_var)
                            .addBands(pcImage)
                            .updateMask(depth_mask)
                          )
                          .regexpRename('_mean', '');
Map.addLayer(segmented_data_mean.reproject(ee.Projection('EPSG:4326').atScale(assets.sensor_scale)), assets.visPamCC, 'SNIC', false);

